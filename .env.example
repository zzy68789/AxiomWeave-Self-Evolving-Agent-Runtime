# Generic API config. Works with Anthropic-compatible endpoints such as DeepSeek.
APIKEY=sk-your-api-key
API=https://api.deepseek.com/anthropic
AXIOMWEAVE_MODEL=claude-sonnet-4-6

# Optional AxiomWeave aliases.
# AXIOMWEAVE_API_KEY=sk-your-api-key
# AXIOMWEAVE_API_BASE=https://api.deepseek.com/anthropic

# Anthropic native config.
# ANTHROPIC_API_KEY=sk-ant-your-api-key
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# OpenAI-compatible config.
# OPENAI_API_KEY=sk-your-api-key
# OPENAI_BASE_URL=https://your-openai-compatible-host/v1
# AXIOMWEAVE_MODEL=gpt-4o
